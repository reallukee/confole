{
  "$schema": "http://json.schemastore.org/template",
  "name": "App Console Confole Vuota",
  "author": "Luca Pollicino",
  "description": "Fornisce un template per la creazione di un'App Console VB vuota con Confole.",
  "defaultName": "ConfoleEmptyApp",
  "language": [
    "VB"
  ],
  "classifications": [
    "Console",
    "Reallukee",
    "Confole"
  ],
  "tags": {
    "language": "VB",
    "type": "project",
    "projectType": "console"
  },
  "sourceName": "ConfoleEmptyApp",
  "identity": "Reallukee.Confole.Templates.EmptyApp.VB",
  "groupIdentity": "Reallukee.Confole.EmptyApp.Templates",
  "shortName": [
    "confole-empty-app"
  ],
  "preferNameDirectory": true,
  "shortcuts": [],
  "symbols": {
    "TargetFrameworkOverride": {
      "type": "parameter",
      "description": "Ignora il framework di destinazione.",
      "replaces": "TargetFrameworkOverride",
      "datatype": "string",
      "defaultValue": "",
      "displayName": "Override del framework di destinazione"
    },
    "Framework": {
      "type": "parameter",
      "description": "Il framework di destinazione per il progetto.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net8.0",
          "description": "Destinazione net8.0.",
          "displayName": ".NET 8.0"
        }
      ],
      "replaces": "net8.0",
      "defaultValue": "net8.0",
      "displayName": "Framework"
    },
    "HostIdentifier": {
      "type": "bind",
      "binding": "HostIdentifier"
    },
    "skipRestore": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Se specificato, ignora il ripristino automatico del progetto durante la creazione.",
      "defaultValue": "false",
      "displayName": "Salta ripristino"
    }
  },
  "primaryOutputs": [
    {
      "path": "ConfoleEmptyApp.vbproj"
    },
    {
      "condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
      "path": "Program.vb"
    }
  ],
  "postActions": [
    {
      "id": "restore",
      "condition": "(!skipRestore)",
      "description": "Ripristinare i pacchetti NuGet richiesti da questo progetto.",
      "manualInstructions": [
        {
          "text": "Esegui 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    },
    {
      "id": "add-confole-sharp",
      "actionId": "B17581D1-C5C9-4489-8F0A-004BE667B814",
      "description": "Aggiunge il pacchetto NuGet Confole# in questo progetto.",
      "manualInstructions": [{
        "text": "Esegui 'dotnet add package Reallukee.Confole.Sharp --version 1.3.0'"
      }],
      "args": {
        "referenceType": "package",
        "reference": "Reallukee.Confole.Sharp",
        "version": "1.3.0",
        "projectFileExtensions": ".vbproj"
      },
      "continueOnError": true
    },
    {
      "id": "open-file",
      "condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
      "description": "Apre Program.vb nell'editor.",
      "manualInstructions": [],
      "actionId": "84C0DA21-51C8-4541-9940-6CA19AF04EE6",
      "args": {
        "files": "1"
      },
      "continueOnError": true
    }
  ]
}
